# Zeilenenden automatisch normalisieren (LF im Repository)
* text=auto

# Web-Dateien immer mit LF
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binärdateien nicht verändern
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
